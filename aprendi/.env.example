# Copy this file to `.env` (same folder) and fill in real values.
# `.env` must NEVER be committed — it's already covered by the repo's
# .gitignore (*.env, *.env.*). This file (.env.example) is the template
# and is safe to commit since it contains no real secrets.

# Gmail account used to SEND the Weekly Learning Brief, per ADR-0003.
# Must have 2-Step Verification enabled, and GMAIL_APP_PASSWORD below
# must be an App Password (myaccount.google.com/apppasswords),
# NOT your normal Gmail password.
GMAIL_ADDRESS=your-sending-account@gmail.com
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# Address that RECEIVES the brief. Can be the same as GMAIL_ADDRESS or a
# different inbox.
BRIEF_RECIPIENT_EMAIL=your-inbox@example.com
